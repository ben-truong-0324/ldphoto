@page
@model LDPhotography.Pages.AboutModel
@{
    ViewData["Title"] = "About Lisa Denberg";
}

<section class="page-section bg-white py-5 mt-4">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5">
                <img src="/images/selfie1.jpg" alt="Lisa Denberg" class="img-fluid shadow-sm" style="border-radius: 4px; width: 100%; object-fit: cover; aspect-ratio: 4/5;" />
            </div>
            <div class="col-lg-7">
                <h1 class="text-uppercase mb-2" style="letter-spacing: 3px;">Lisa Denberg</h1>
                <p class="text-muted small text-uppercase fw-bold mb-4">
                    <i class="fas fa-map-marker-alt me-1 text-danger"></i> Vacaville, CA &nbsp;|&nbsp; 🇷🇺 🇺🇸
                </p>
                
                <p class="lead serif-font mb-4" style="font-size: 1.35rem; line-height: 1.6;">
                    Hi, I'm Lisa (she/her). I am a photographer specializing in landscape and environmental portraits, finding the quiet beauty where human life meets the natural world.
                </p>
                
                <p class="text-muted mb-3" style="line-height: 1.8;">
                    I explore the wilderness to find inner peace and share it through my lens. Being autistic gives me a unique perspective - a deep appreciation for the subtle details, lighting, and natural patterns that others might walk right past. 
                </p>
                
                <p class="text-muted" style="line-height: 1.8;">
                    Whether I am out capturing the shifting seasons of the Pacific Northwest or working one-on-one for a portrait session, my goal is always to create imagery that feels grounded, serene, and deeply connected to the environment.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="page-section bg-light py-5" id="services" style="scroll-margin-top: 100px;">
    <div class="container">
        <div class="text-center mb-5 pb-2">
            <h2 class="text-uppercase border-bottom border-dark d-inline-block pb-2" style="letter-spacing: 3px;">Private Services</h2>
        </div>
        
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h4 class="serif-font mb-3 fs-3">Photographer for Hire</h4>
                <p class="text-muted mb-5">
                    Looking for a photographer who understands how to blend subjects seamlessly into beautiful natural environments? I am available for private hire across Solano County and beyond.
                </p>
                
                <div class="row g-4 text-start justify-content-center mb-5">
                    <div class="col-md-10">
                        <div class="d-flex mb-4">
                            <div class="me-3 mt-1"><i class="fas fa-leaf text-success fs-4"></i></div>
                            <div>
                                <h5 class="fw-bold mb-1">Environmental Portraits</h5>
                                <p class="text-muted small mb-0">Couples, individuals, and families captured using natural lighting and stunning outdoor backdrops.</p>
                            </div>
                        </div>
                        <div class="d-flex mb-4">
                            <div class="me-3 mt-1"><i class="fas fa-camera-retro text-success fs-4"></i></div>
                            <div>
                                <h5 class="fw-bold mb-1">Custom Landscape Commissions</h5>
                                <p class="text-muted small mb-0">Have a specific local park, property, or landscape you want professionally captured for your home?</p>
                            </div>
                        </div>
                        <div class="d-flex">
                            <div class="me-3 mt-1"><i class="fas fa-calendar-check text-success fs-4"></i></div>
                            <div>
                                <h5 class="fw-bold mb-1">Private Event Photography</h5>
                                <p class="text-muted small mb-0">Candid, nature-focused photography for intimate outdoor gatherings and events.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <a href="mailto:denberglisa@yahoo.com" class="btn btn-dark btn-lg text-uppercase px-5 py-3 fw-bold shadow-sm" style="letter-spacing: 1px;">Inquire for Booking</a>
                
            </div>
        </div>
    </div>
</section>