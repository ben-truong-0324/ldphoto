@page
@model PortfolioShop.Pages.Checkout.ConfirmationModel
@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="text-center">
    <h1 class="display-4">Thank You!</h1>
    <p class="lead">Your order has been confirmed.</p>
    <p>Order Number: <strong>@Model.Order.OrderNumber</strong></p>
    <p>A confirmation email has been sent to: <strong>@Model.Order.CustomerEmail</strong></p>
    <a asp-page="/Index" class="btn btn-primary">Continue Shopping</a>
</div>