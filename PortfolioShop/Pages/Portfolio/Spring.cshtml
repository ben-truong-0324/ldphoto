@page
@model LDPhotography.Pages.Portfolio.SpringModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="portfolio-detail-container">
    <section class="hero-feature">
        <div class="container-fluid p-0">
            <img src="@Model.HeroImage.Url" alt="@Model.HeroImage.AltText" class="img-fluid w-100 featured-image" />
        </div>
    </section>

    <section class="collection-intro py-5">
        <div class="container text-center">
            <h1 class="text-uppercase mb-4">@Model.Title</h1>
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <p class="serif-font italic text-muted lead">
                        @Model.Description
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="collection-carousel pb-5">
        <div class="container">
            <div id="springCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @for (int i = 0; i < Model.GalleryImages.Count; i++)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <img src="@Model.GalleryImages[i].Url" class="d-block w-100 gallery-slide-img" alt="@Model.GalleryImages[i].AltText">
                            <div class="carousel-caption d-none d-md-block">
                                <h5 class="serif-font">@Model.GalleryImages[i].Caption</h5>
                            </div>
                        </div>
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#springCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#springCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <style>
        .featured-image {
            max-height: 80vh;
            object-fit: cover;
            filter: grayscale(20%); /* Subtle aesthetic touch */
        }
        .collection-intro h1 {
            letter-spacing: 6px;
            font-weight: 300;
        }
        .gallery-slide-img {
            max-height: 600px;
            object-fit: contain;
            background-color: #f8f9fa;
        }
        .carousel-caption {
            background: rgba(255, 255, 255, 0.8);
            color: #000;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 1rem;
        }
        .carousel-control-prev-icon, .carousel-control-next-icon {
            filter: invert(1); /* Makes controls visible on light photos */
        }
    </style>
}