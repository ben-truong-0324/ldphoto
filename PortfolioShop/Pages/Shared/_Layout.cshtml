<!DOCTYPE html>
<html lang="en-US">
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="~/css/agency.css" rel="stylesheet" />
<link href="~/css/bootstrap.css" rel="stylesheet" />
<link href="~/css/site.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    </head>
<body id="page-top" dir="ltr">

    @inject CartService CartService

    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
        <div class="container">
            <!-- <a class="navbar-brand d-inline-block text-truncate" asp-page="/Index" style="max-width: 65vw; font-size: 1.25rem;">
                LDPhotography
            </a> -->
        
            <a class="navbar-brand d-inline-block text-truncate me-0" asp-page="/Index" style="max-width: calc(100vw - 140px); font-size: 1.15rem;">
                LDPhotography
            </a>
            
            <button class="navbar-toggler navbar-toggler-right" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive">
                <i class="fas fa-bars ms-1"></i>
            </button>

            <div class="collapse navbar-collapse" id="navbarResponsive">
                <ul class="navbar-nav text-uppercase ms-auto py-4 py-lg-0">
                    <li class="nav-item"><a class="nav-link" href="/about">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="/About#services">Booking</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#portfolio">Portfolio</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Shop/Index">Shop</a></li>
                    
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Shop/Cart">
                            <i class="fas fa-shopping-cart"></i> Cart
                            @{
                                var cartCount = await CartService.GetCartCountAsync();
                                if (cartCount > 0)
                                {
                                    <span class="badge bg-danger rounded-pill">@cartCount</span>
                                }
                            }
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

        <footer class="aa-footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-5 mb-lg-0">
                    <h5>My Philosophy</h5>
                    <p class="mission-statement"> I strive to cultivate an aesthetic appreciation for the
                        natural world, offering a unique collection of fine art prints and professional photographic
                        services inspired by the legacy of classical landscape masters. </p>
                    <div class="contact-info"> Monday to Sunday 10a – 5p<br> Fairfield, California<br> <a
                            class="footer-link d-inline">LDenbergphotography</a> </div>
                </div>
                <div class="col-lg-2 col-md-4 mb-4 mb-md-0">
                        <h5>The Shop</h5> 
                        <a class="footer-link d-block" href="/Shop/Index#spring">Spring Collection</a> 
                        <a class="footer-link d-block" href="/Shop/Index#summer">Summer Series</a> 
                        <a class="footer-link d-block" href="/Shop/Index#autumn">Autumn Series</a> 
                        <a class="footer-link d-block" href="/Shop/Index#winter">Winter Collection</a> 
                </div>
                <div class="col-lg-2 col-md-4 mb-4 mb-md-0">
                    <h5>Information</h5> 
                    <a class="footer-link d-block mb-2" asp-page="/About">About me</a> 
                    <a class="footer-link d-block mb-2" href="/About#services">Hire me!</a>
                    <!-- <a class="footer-link" href="/articles">Articles &amp; News</a> 
                    <a class="footer-link" href="/reviews">Client Reviews</a> <a class="footer-link" href="/faq">Trade &amp; Licensing</a> -->
                </div>
                <div class="col-lg-4 col-md-4">
                    <h5>Connect</h5>
                    <p class="small mb-4">Follow and explore the life and art of nature with me
                        photography.</p>
                    <div class="social-icons mb-4"> <a class="btn btn-dark btn-social"
                            href="https://www.instagram.com/ldenbergphotography/"><i class="fab fa-instagram"></i></a>
                        <a class="btn btn-dark btn-social"
                            href="https://www.facebook.com/profile.php?id=100087780196898"><i
                                class="fab fa-facebook-f"></i></a> </div>
                </div>
            </div>
            <div class="row bottom-bar">
                <div class="col-lg-6 text-center text-lg-start mb-3 mb-lg-0"> Copyright © LDenberg Photography 2026
                </div>
                <div class="col-lg-6 text-center text-lg-end"> 
                <!-- <a class="footer-link d-inline mx-2" href="#!">Privacy Policy</a> 
                <a class="footer-link d-inline mx-2" href="#!">Terms &amp; Conditions</a> 
                <a class="footer-link d-inline mx-2" href="#!">Shipping Policy</a> -->
                    Photos captured with ❤️ from California
                 </div>
            </div>
        </div>
     </footer>
     

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    </body>
</html>