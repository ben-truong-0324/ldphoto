@page "{orderNumber}"
@model OrderConfirmationModel
@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="container text-center mt-5 pt-5">
    <div class="py-5">
        <i class="fas fa-check-circle text-success fa-5x mb-3"></i>
        <h2>Thank you for your order, @Model.Order?.CustomerName!</h2>
        <p class="lead">Your order number is: <strong>@Model.Order?.OrderNumber</strong></p>
        <hr class="my-4" />
        
        <div class="row justify-content-center">
            <div class="col-md-8 text-start">
                <h5 class="mb-3">Order Summary</h5>
                <ul class="list-group mb-4 shadow-sm">
                    @foreach (var item in Model.Order?.OrderItems ?? new())
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.ProductName" class="rounded me-3 shadow-sm" style="width: 75px; height: 75px; object-fit: cover;" />
                                }

                                <div>
                                    <h6 class="my-0 fw-bold">@item.ProductName <span class="text-muted fw-normal ms-1">(Qty: @item.Quantity)</span></h6>
                                    
                                    <div class="mt-1">
                                        <small class="text-muted me-2">
                                            <i class="fas fa-camera-retro me-1"></i>@item.Format 
                                            @if (!string.IsNullOrEmpty(item.Size))
                                            {
                                                <span>(@item.Size)</span>
                                            }
                                        </small>
                                        
                                        @if(item.Finish != global::Portfolio.Core.Models.PrintFinish.None) 
                                        {
                                            <small class="text-muted me-2">
                                                <i class="fas fa-fill-drip me-1"></i>@item.Finish
                                            </small>
                                        }
                                        
                                        @if(item.IsFramed) 
                                        {
                                            <small class="text-success fw-bold">
                                                <i class="fas fa-border-all me-1"></i>Framed
                                            </small>
                                        }
                                    </div>
                                </div>
                            </div>
                            
                            <span class="fw-bold">@((item.Price * item.Quantity).ToString("C"))</span>
                        </li>
                    }
                    <li class="list-group-item d-flex justify-content-between bg-light py-3">
                        <strong class="fs-5">Total Paid</strong>
                        <strong class="fs-5 text-primary" style="color:var(--sage-green)!important;">@Model.Order?.TotalAmount.ToString("C")</strong>
                    </li>
                </ul>
            </div>
        </div>

        <p class="text-muted">A confirmation email has been sent to @Model.Order?.CustomerEmail.</p>
        <a asp-page="/Index" class="btn btn-primary mt-3 px-4 py-2">Return to Gallery</a>
    </div>
</div>